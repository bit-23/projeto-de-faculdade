{
  "name": "gqwen-auth",
  "version": "4.1.0",
  "description": "Qwen OAuth account manager and OpenAI-compatible proxy CLI",
  "author": "gxdev",
  "license": "MIT",
  "keywords": [
    "qwen",
    "ai",
    "openai",
    "proxy",
    "oauth",
    "cli"
  ],
  "bin": {
    "gqwen": "./dist/gqwen"
  },
  "files": [
    "dist/gqwen"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "module": "index.ts",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "bun --hot index.ts serve fg",
    "start": "bun index.ts serve fg",
    "build": "bun build index.ts --target bun --outfile dist/gqwen && chmod +x dist/gqwen",
    "prepublishOnly": "bun run build",
    "install:cli": "bash setup.sh",
    "uninstall:cli": "bash uninstall.sh"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "open": "^11.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
