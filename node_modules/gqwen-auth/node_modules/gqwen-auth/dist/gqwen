async function loadStatus() {
  try { const r = await fetch('/api/status'); statusData = await r.json(); renderStatus(statusData); } catch {}
}

function fmtNum(n) {
  if (n>=1e6) return (n/1e6).toFixed(1)+'M';
  if (n>=1e3) return (n/1e3).toFixed(1)+'k';
  return String(n);
}

function statusTag(acc) {
  if (!acc.is_active) return '<span class="tag tag-disabled">'+T.toggle_enable+'</span>';
  // Use effective_status (server normalises unavailable\u2192active when lock expired)
  const st = acc.effective_status || acc.test_status;
  if (st==='active')      return '<span class="tag tag-active">&#x2713; Active</span>';
  if (st==='unavailable') return '<span class="tag tag-unavail">&#x2717; Rate limited</span>';
  return '<span class="tag tag-unknown">&#x25CC; Ready</span>';
}

function renderStatus(d) {
  const {proxy,accounts,usage} = d;
  const dot = document.getElementById('proxy-pill-dot');
  const lbl = document.getElementById('proxy-pill-label');
  dot.className = 'dot '+(proxy.running?'dot-on':'dot-off');
  lbl.textContent = proxy.running ? T.status_running+' \xB7 :'+proxy.port : T.status_stopped;
  lbl.style.color = proxy.running?'#22c55e':'#6b7280';
  // sync mobile dots
  const mobDot = document.getElementById('mob-proxy-dot');
  if (mobDot) { mobDot.className = 'dot '+(proxy.running?'dot-on':'dot-off'); mobDot.title = lbl.textContent; }
  const mobDrDot = document.getElementById('mob-drawer-dot');
  const mobDrSt  = document.getElementById('mob-drawer-status');
  if (mobDrDot) mobDrDot.className = 'dot '+(proxy.running?'dot-on':'dot-off');
  if (mobDrSt)  { mobDrSt.textContent = lbl.textContent; mobDrSt.style.color = proxy.running?'#22c55e':'#6b7280'; }
  // Sync power button state (only if not mid-stop animation)
  const pwrBtn = document.getElementById('btn-server-power');
  if (pwrBtn && !pwrBtn.dataset.stopping) {
    pwrBtn.style.opacity = '1';
    pwrBtn.classList.remove('power-on','power-off','power-confirming');
    if (proxy.running) {
      pwrBtn.classList.add('power-on');
      pwrBtn.disabled = false;
      document.getElementById('server-power-label').textContent = 'Stop server';
      document.getElementById('server-power-icon').setAttribute('icon','solar:power-bold-duotone');
    } else {
      pwrBtn.classList.add('power-off');
      pwrBtn.disabled = true;
      document.getElementById('server-power-label').textContent = 'Stopped';
      document.getElementById('server-power-icon').setAttribute('icon','solar:power-bold-duotone');
    }
  }
  document.getElementById('proxy-strategy').textContent = proxy.strategy+(proxy.strategy==='round-robin'?' (x'+proxy.stickyLimit+')':'');
  const st = document.getElementById('proxy-status-text');
  st.textContent = proxy.running ? T.status_running+' (PID '+proxy.pid+')' : T.status_stopped;
  st.style.color = proxy.running?'#22c55e':'#ef4444';
  animN('kpi-total', accounts.total);
  animN('kpi-active', accounts.active);
  animN('kpi-requests', usage.totals.requests);
  document.getElementById('kpi-tokens').textContent = fmtNum(usage.totals.total_tokens);
  const subParts = [];
  if (accounts.unavailable > 0) subParts.push(accounts.unavailable+' rate limited');
  if (accounts.unknown > 0) subParts.push(accounts.unknown+' not tested yet');
  document.getElementById('kpi-total-sub').textContent = subParts.length ? subParts.join(' \xB7 ') : 'all healthy';
  const me = document.getElementById('usage-by-model');
  if (!usage.byModel.length) { me.innerHTML='<p style="font-size:0.85rem;color:#6b7280;">'+T.no_usage+'</p>'; }
  else {
    const tot = usage.totals.total_tokens||1;
    me.innerHTML = usage.byModel.map(m => {
      const pct = Math.round(m.total_tokens/tot*100);
      return '<div style="margin-bottom:1rem;"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.375rem;"><span style="font-size:0.82rem;font-weight:600;color:#0AB9DC;">'+m.model+'</span><span style="font-size:0.72rem;color:#6b7280;">'+fmtNum(m.total_tokens)+'t \xB7 '+m.requests+' req</span></div><div style="height:5px;background:#222;border-radius:9999px;overflow:hidden;"><div style="height:100%;width:'+pct+'%;background:#0AB9DC;border-radius:9999px;transition:width 0.6s ease;"></div></div><div style="display:flex;justify-content:space-between;font-size:0.7rem;color:#6b7280;margin-top:0.25rem;"><span>in '+fmtNum(m.prompt_tokens)+'</span><span>out '+fmtNum(m.completion_tokens)+'</span></div></div>';
    }).join('');
  }
  renderAccountsList('accounts-list', accounts.list.slice(0,6));
  const afl = document.getElementById('accounts-list-full');
  if (afl && !document.getElementById('tab-accounts').classList.contains('hidden'))
    renderAccountsList('accounts-list-full', accounts.list);
}

function renderAccountsList(id, list) {
  const el = document.getElementById(id); if (!el) return;
  if (!list||!list.length) {
    el.innerHTML='<div style="text-align:center;padding:2rem 0;"><iconify-icon icon="solar:user-cross-bold-duotone" style="color:#6b7280;font-size:2rem;display:block;margin-bottom:0.5rem;"></iconify-icon><p style="font-size:0.85rem;color:#6b7280;margin-bottom:0.875rem;">'+T.no_accounts+'</p><button class="btn-primary" style="margin:0 auto;height:2.5rem;padding:0 1rem;font-size:0.82rem;" onclick="openAddModal()"><iconify-icon icon="solar:user-plus-bold-duotone"></iconify-icon> '+T.add_first+'</button></div>';
    return;
  }
  el.innerHTML = list.map((acc,i) => {
    const label = acc.email||(acc.id.slice(0,14)+'\u2026');
    const tok   = acc.usage ? fmtNum(acc.usage.total_tokens)+'t' : '\u2014';
    const lu    = acc.last_used_at ? new Date(acc.last_used_at).toLocaleDateString() : T.never;
    const border = i<list.length-1 ? 'border-bottom:1px solid #1e1e1e;' : '';
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 0;'+border+'gap:0.5rem;flex-wrap:wrap;"><div style="display:flex;align-items:center;gap:0.625rem;min-width:0;flex:1;"><div style="width:2rem;height:2rem;border-radius:50%;background:rgba(10,185,220,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><iconify-icon icon="solar:user-bold-duotone" style="color:#0AB9DC;font-size:0.9rem;"></iconify-icon></div><div style="min-width:0;"><p style="font-size:0.85rem;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+label+'</p><p style="font-size:0.72rem;color:#6b7280;">'+tok+' \xB7 '+T.last_used+' '+lu+'</p></div></div><div class="acc-row-actions" style="display:flex;align-items:center;gap:0.375rem;flex-shrink:0;">'+statusTag(acc)+'<button class="btn-icon" onclick="toggleAcc(\\''+acc.id+'\\')" title="'+(acc.is_active?T.toggle_disable:T.toggle_enable)+'"><iconify-icon icon="'+(acc.is_active?'solar:pause-bold-duotone':'solar:play-bold-duotone')+'" style="font-size:0.85rem;"></iconify-icon></button><button class="btn-sm btn-sm-danger" onclick="removeAcc(\\''+acc.id+'\\',\\''+label.replace(/'/g,"\\\\'").replace(/"/g,'')+'\\')" ><iconify-icon icon="solar:trash-bin-trash-bold-duotone"></iconify-icon><span class="btn-remove-lbl">'+T.remove+'</span></button></div></div>';
  }).join('');
}

// \u2500\u2500 Server power button \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
let _powerConfirmTimer = null;

function handleServerPower() {
  const btn = document.getElementById('btn-server-power');
  if (!btn || btn.disabled || btn.dataset.stopping) return;

  if (btn.classList.contains('power-confirming')) {
    // Second click \u2014 confirmed, do the stop
    clearTimeout(_powerConfirmTimer);
    _powerConfirmTimer = null;
    _doStopServer(btn);
    return;
  }

  // First click \u2014 enter confirm state
  btn.classList.remove('power-on');
  btn.classList.add('power-confirming');
  document.getElementById('server-power-icon').setAttribute('icon','solar:shield-warning-bold-duotone');
  document.getElementById('server-power-label').textContent = 'Confirm stop?';

  _powerConfirmTimer = setTimeout(() => {
    _powerConfirmTimer = null;
    btn.classList.remove('power-confirming');
    btn.classList.add('power-on');
    document.getElementById('server-power-icon').setAttribute('icon','solar:power-bold-duotone');
    document.getElementById('server-power-label').textContent = 'Stop server';
  }, 2500);
}

async function _doStopServer(btn) {
  btn.dataset.stopping = '1';
  btn.disabled = true;
  btn.classList.remove('power-confirming','power-on');
  document.getElementById('server-power-icon').setAttribute('icon','solar:power-bold-duotone');

  // Kill auto-poll so we don't spam dead server
  if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
  const apBtn = document.getElementById('btn-autopoll');
  if (apBtn) { apBtn.classList.remove('autopoll-on'); document.getElementById('autopoll-dot').style.display='none'; }

  document.getElementById('server-power-label').textContent = 'Stopping\u2026';
  document.getElementById('server-power-icon').setAttribute('icon','solar:power-bold-duotone');

  try { await fetch('/api/proxy/stop', {method:'POST'}); } catch {}

  // Animate the pill to "stopping"
  const dot = document.getElementById('proxy-pill-dot');
  const lbl = document.getElementById('proxy-pill-label');
  dot.className = 'dot dot-warn dot-pulse';
  lbl.textContent = 'stopping\u2026';
  lbl.style.color = '#6b7280';

  setTimeout(() => {
    dot.className = 'dot dot-off';
    lbl.textContent = T.status_stopped;
    btn.classList.add('power-off');
    btn.disabled = true;
    document.getElementById('server-power-label').textContent = 'Stopped';
    delete btn.dataset.stopping;
  }, 1000);
}

async function toggleAcc(id) { try { await fetch('/api/accounts/'+id+'/toggle',{method:'POST'}); await loadStatus(); } catch {} }
async function removeAcc(id,label) {
  if (!confirm(T.confirm_remove+' "'+label+'"?')) return;
  try { await fetch('/api/accounts/'+id,{method:'DELETE'}); await loadStatus(); } catch {}
}

function animN(id, target) {
  const el = document.getElementById(id); if (!el) return;
  const obj = { v: parseInt(el.textContent)||0 };
  gsap.to(obj,{v:target,duration:0.7,ease:'power2.out',onUpdate:()=>{ el.textContent=Math.round(obj.v); }});
}

// \u2500\u2500 Config \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
let cfgStrategy = 'fill-first', cfgStickyLimit = 3;

async function loadConfig() {
  try {
    const r = await fetch('/api/config');
    const d = await r.json();
    cfgStrategy    = d.strategy;
    cfgStickyLimit = d.stickyLimit;
    renderConfig(d);
  } catch {}
}

function renderConfig(d) {
  cfgStrategy    = d.strategy;
  cfgStickyLimit = d.stickyLimit;
  selectStrategy(d.strategy, true);
  document.getElementById('cfg-sticky-val').textContent = d.stickyLimit;
  const port = d.port;
  document.getElementById('cfg-port-input').value = port;
  document.getElementById('cfg-endpoint-val').textContent = 'http://localhost:'+port+'/v1';
}

function selectStrategy(s, silent) {
  cfgStrategy = s;
  const fillBtn = document.getElementById('cfg-btn-fill');
  const rrBtn   = document.getElementById('cfg-btn-rr');
  const stickyRow = document.getElementById('cfg-sticky-row');
  const isRR = s === 'round-robin';
  fillBtn.style.borderColor = isRR ? '#2a2a2a' : '#0AB9DC';
  fillBtn.style.background  = isRR ? '#1a1a1a' : 'rgba(10,185,220,0.08)';
  rrBtn.style.borderColor   = isRR ? '#0AB9DC' : '#2a2a2a';
  rrBtn.style.background    = isRR ? 'rgba(10,185,220,0.08)' : '#1a1a1a';
  stickyRow.style.display   = isRR ? 'flex' : 'none';
}

function adjSticky(delta) {
  cfgStickyLimit = Math.max(1, Math.min(100, cfgStickyLimit + delta));
  document.getElementById('cfg-sticky-val').textContent = cfgStickyLimit;
}

async function saveConfig() {
  const btn = document.getElementById('cfg-save-btn');
  const lbl = document.getElementById('cfg-save-label');
  btn.disabled = true;
  try {
    const r = await fetch('/api/config', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ strategy: cfgStrategy, stickyLimit: cfgStickyLimit })
    });
    const d = await r.json();
    if (d.ok) {
      lbl.textContent = T.cfg_saved || 'Saved!';
      setTimeout(() => { lbl.textContent = T.cfg_save || 'Save changes'; btn.disabled = false; }, 1800);
      renderConfig(d);
      // Refresh overview strategy display
      if (statusData) { statusData.proxy.strategy = d.strategy; statusData.proxy.stickyLimit = d.stickyLimit; renderStatus(statusData); }
    } else { btn.disabled = false; }
  } catch { btn.disabled = false; }
}

async function savePort() {
  const portInput = document.getElementById('cfg-port-input');
  const saveBtn   = document.getElementById('cfg-port-save');
  const port = parseInt(portInput.value, 10);
  if (!port || port < 1 || port > 65535) return;
  saveBtn.textContent = '\u2026';
  try {
    const r = await fetch('/api/config', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ port })
    });
    const d = await r.json();
    if (d.ok) {
      document.getElementById('cfg-endpoint-val').textContent = 'http://localhost:'+d.port+'/v1';
      saveBtn.textContent = T.cfg_saved || 'Saved!';
      setTimeout(() => { saveBtn.textContent = T.cfg_port_save || 'Save'; }, 1800);
    } else { saveBtn.textContent = T.cfg_port_save || 'Save'; }
  } catch { saveBtn.textContent = T.cfg_port_save || 'Save'; }
}

async function unlockAll() {
  const btn = document.getElementById('cfg-unlock-btn');
  const lbl = document.getElementById('cfg-unlock-btn-label');
  btn.disabled = true;
  try {
    await fetch('/api/unlock', { method:'POST' });
    lbl.textContent = T.cfg_unlocked || 'Unlocked!';
    setTimeout(() => { lbl.textContent = T.cfg_unlock_btn || 'Unlock'; btn.disabled = false; }, 2000);
    loadStatus();
  } catch { btn.disabled = false; }
}

// \u2500\u2500 Add Account Modal \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
function openAddModal() {
  const modal = document.getElementById('add-modal');
  if (!modal) return;
  // Reset to idle state
  document.getElementById('modal-idle').classList.remove('hidden');
  document.getElementById('modal-started').classList.add('hidden');
  document.getElementById('modal-success').classList.add('hidden');
  if (modalPollTimer) { clearInterval(modalPollTimer); modalPollTimer = null; }
  modal.classList.remove('hidden');
}

function closeAddModal() {
  const modal = document.getElementById('add-modal');
  if (!modal) return;
  if (modalPollTimer) { clearInterval(modalPollTimer); modalPollTimer = null; }
  modal.classList.add('hidden');
}

async function startModalAuth() {
  try {
    document.getElementById('modal-idle').querySelector('button').disabled = true;
    const res = await fetch('/api/auth/start', { method: 'POST' });
    if (!res.ok) throw new Error('Failed to start auth');
    const data = await res.json();

    document.getElementById('modal-usercode').textContent = data.user_code;
    const urlEl = document.getElementById('modal-urllink');
    urlEl.href = data.verification_uri_complete || data.verification_uri;
    document.getElementById('modal-urltext').textContent = data.verification_uri_complete || data.verification_uri;
    document.getElementById('modal-pollstatus').textContent = T.modal_pollwait || 'Open the URL above and enter the code\u2026';

    document.getElementById('modal-idle').classList.add('hidden');
    document.getElementById('modal-started').classList.remove('hidden');

    const interval = (data.interval || 5) * 1000;
    modalPollTimer = setInterval(async () => {
      try {
        const pr = await fetch('/api/auth/poll', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ device_code: data.device_code }),
        });
        const pd = await pr.json();
        if (pd.status === 'complete') {
          clearInterval(modalPollTimer); modalPollTimer = null;
          document.getElementById('modal-successemail').textContent = pd.account?.email || '';
          document.getElementById('modal-started').classList.add('hidden');
          document.getElementById('modal-success').classList.remove('hidden');
        } else if (pd.status === 'expired' || pd.status === 'denied') {
          clearInterval(modalPollTimer); modalPollTimer = null;
          document.getElementById('modal-pollstatus').textContent = pd.status === 'denied' ? 'Access denied.' : 'Code expired. Please try again.';
        }
      } catch { /* keep polling */ }
    }, interval);
  } catch (err) {
    const btn = document.getElementById('modal-idle').querySelector('button');
    btn.disabled = false;
    alert('Error: ' + err.message);
  }
}

// \u2500\u2500 Auto-poll \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
let autoPollTimer = null;
const AUTO_POLL_MS = 5000;

function toggleAutoPoll() {
  const btn   = document.getElementById('btn-autopoll');
  const dot   = document.getElementById('autopoll-dot');
  const badge = document.getElementById('mob-autopoll-badge');
  if (autoPollTimer) {
    clearInterval(autoPollTimer);
    autoPollTimer = null;
    btn.classList.remove('autopoll-on');
    dot.style.display = 'none';
    if (badge) { badge.textContent='OFF'; badge.style.background='#1e1e1e'; badge.style.color='#4b5563'; }
  } else {
    autoPollTimer = setInterval(() => loadStatus(), AUTO_POLL_MS);
    btn.classList.add('autopoll-on');
    dot.style.display = 'block';
    if (badge) { badge.textContent='ON'; badge.style.background='rgba(34,197,94,0.12)'; badge.style.color='#22c55e'; }
  }
}

function manualRefresh() {
  const btn = document.getElementById('btn-refresh');
  btn.classList.add('spin-once');
  btn.addEventListener('animationend', () => btn.classList.remove('spin-once'), { once: true });
  loadStatus();
}

// \u2500\u2500 Loading overlay animation \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
let loadingInterval = null;

function startLoadingAnim() {
  const art = document.getElementById('dash-loading-art');
  const asciiFrames = window.asciiFrames;
  if (!art || !Array.isArray(asciiFrames) || !asciiFrames.length) return;
  let idx = 0;
  art.textContent = asciiFrames[0];
  loadingInterval = setInterval(() => {
    idx = (idx + 1) % asciiFrames.length;
    art.textContent = asciiFrames[idx];
  }, 1000 / 15);
}

function stopLoadingAnim() {
  clearInterval(loadingInterval);
  loadingInterval = null;
  const overlay = document.getElementById('dash-loading');
  if (!overlay) return;
  gsap.to(overlay, {
    opacity: 0, duration: 0.45, ease: 'power2.inOut',
    onComplete: () => { overlay.style.display = 'none'; }
  });
  gsap.fromTo('#dashboard', { opacity: 0 }, { opacity: 1, duration: 0.4, delay: 0.2, ease: 'power2.out' });
}

window.addEventListener('load', () => {
  applyI18n();
  document.getElementById('dashboard').style.opacity = '0';
  startLoadingAnim();
  loadStatus().finally(() => stopLoadingAnim());
  toggleAutoPoll();
  checkDashboardVersion();
});
</script>
<script src="/public/animation.js"></script>
</body>
</html>
