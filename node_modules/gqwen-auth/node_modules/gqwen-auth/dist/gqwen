    });
  } catch (err) {
    return json({ error: String(err) }, 500);
  }
}
async function handleAuthPoll(req) {
  try {
    const body = await req.json();
    const session = pendingSessions.get(body.device_code);
    if (!session) {
      return json({ status: "expired" });
    }
    if (Date.now() > session.expiresAt) {
      pendingSessions.delete(body.device_code);
      return json({ status: "expired" });
    }
    const pollBody = new URLSearchParams({
      grant_type: "urn:ietf:params:oauth:grant-type:device_code",
      device_code: session.deviceCode,
      client_id: QWEN_CLIENT_ID,
      code_verifier: session.codeVerifier
    });
    const resp = await fetch(QWEN_TOKEN_URL, {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded", Accept: "application/json" },
      body: pollBody
    });
    if (resp.ok) {
      const tokens = await resp.json();
      pendingSessions.delete(body.device_code);
      const email = tokens.id_token ? parseIdTokenEmail(tokens.id_token) : null;
      const expiresAt = new Date(Date.now() + tokens.expires_in * 1000).toISOString();
      const account = addAccount({
        email,
        display_name: email,
        access_token: tokens.access_token,
        refresh_token: tokens.refresh_token,
        expires_at: expiresAt,
        resource_url: tokens.resource_url ?? null
      });
      return json({ status: "complete", account });
    }
    const data = await resp.json().catch(() => ({}));
    const error = data.error;
    if (error === "authorization_pending" || error === "slow_down") {
      return json({ status: "pending" });
    }
    if (error === "expired_token") {
      pendingSessions.delete(body.device_code);
      return json({ status: "expired" });
    }
    if (error === "access_denied") {
      pendingSessions.delete(body.device_code);
      return json({ status: "denied" });
    }
    return json({ status: "error", message: data.error_description ?? error ?? "unknown" });
  } catch (err) {
    return json({ error: String(err) }, 500);
  }
}
