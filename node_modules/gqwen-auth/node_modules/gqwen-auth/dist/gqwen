});

function runSplash() {
  const art  = document.getElementById('splash-art');
  const SPLASH_DURATION = 3000; // ms
  const FPS = 15; // 45 frames / 15fps = 3s

  // asciiFrames is set by /public/animation.js via window.asciiFrames = frames
  const asciiFrames = window.asciiFrames;
  if (!Array.isArray(asciiFrames) || !asciiFrames.length) {
    endSplash(); return;
  }

  let idx = 0;
  art.textContent = asciiFrames[0];

  const interval = setInterval(() => {
    idx = (idx + 1) % asciiFrames.length;
    art.textContent = asciiFrames[idx];
  }, 1000 / FPS);

  setTimeout(() => {
    clearInterval(interval);
    endSplash();
  }, SPLASH_DURATION);
}

function endSplash() {
  gsap.to('#splash', {
    opacity: 0, duration: 0.6, ease: 'power2.inOut',
    onComplete: () => {
      document.getElementById('splash').style.display = 'none';
    }
  });
  gsap.fromTo('#wizard', { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.5, delay: 0.3, ease: 'power3.out' });
}
