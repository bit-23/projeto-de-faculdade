// \u2500\u2500 Auth flow shared \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
async function startAuthFlow(target) {
  const pfx = target === 'wizard' ? 's1' : 'modal';
  document.getElementById(pfx+'-idle').classList.add('hidden');
  document.getElementById(pfx+'-started').classList.remove('hidden');
  document.getElementById(pfx+'-pollstatus').textContent = target==='wizard' ? T.s1_pollwait : T.modal_pollwait;
  try {
    const res  = await fetch('/api/auth/start', { method:'POST' });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    document.getElementById(pfx+'-usercode').textContent = data.user_code;
    document.getElementById(pfx+'-codelabel').textContent = target==='wizard' ? T.s1_codelabel : T.modal_codelabel;
    const url = data.verification_uri_complete || data.verification_uri;
    document.getElementById(pfx+'-urllink').href = url;
    document.getElementById(pfx+'-urltext').textContent = url;
    document.getElementById(pfx+'-pollstatus').textContent = target==='wizard' ? T.s1_pollwait : T.modal_pollwait;
    const timer = setInterval(() => doPoll(data.device_code, target), (data.interval||5)*1000);
    if (target==='wizard') pollTimer = timer; else modalPollTimer = timer;
  } catch(e) {
    document.getElementById(pfx+'-pollstatus').textContent = 'Error: '+e.message;
  }
}
function startAuth()      { startAuthFlow('wizard'); }
function startModalAuth() { startAuthFlow('modal'); }

async function doPoll(deviceCode, target) {
  try {
    const res  = await fetch('/api/auth/poll', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({device_code:deviceCode}) });
    const data = await res.json();
    if (data.status === 'complete') {
      clearInterval(target==='wizard' ? pollTimer : modalPollTimer);
      if (target==='wizard') showWizardSuccess(data.account);
      else showModalSuccess(data.account);
    } else if (['expired','denied','error'].includes(data.status)) {
      clearInterval(target==='wizard' ? pollTimer : modalPollTimer);
      const pfx = target==='wizard'?'s1':'modal';
      document.getElementById(pfx+'-pollstatus').textContent = data.status==='denied'?'Authorization denied.':'Code expired. Please try again.';
    }
  } catch {}
}

