async function updateAddDonorCommand(name, valueStr) {
  const value = parseFloat(valueStr.replace(",", "."));
  if (!name || isNaN(value) || value <= 0) {
    console.error(source_default.red(`
  Usage: gqwen update add-donor <name> <value>
`));
    process.exit(1);
  }
  const spinner = ora({ text: `Adding donor ${source_default.cyan(name)} (${fmtBRL(value)})\u2026`, indent: 2 }).start();
  const ok = await addDonor(name, value);
  if (ok) {
    spinner.succeed(`Donor ${source_default.cyan(name)} added \u2014 ${source_default.green(fmtBRL(value))}`);
