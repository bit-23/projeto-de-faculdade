function showTab(tab) {
  ['overview','accounts','settings','donate'].forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('hidden', t!==tab);
    const navEl = document.getElementById('nav-'+t);
    if (navEl) {
      if (t === 'donate') navEl.classList.toggle('active', t===tab);
      else navEl.classList.toggle('active', t===tab);
    }
    // sync mobile bottom nav
    const mobTab = document.getElementById('mob-tab-'+t);
    if (mobTab) mobTab.classList.toggle('active', t===tab);
    // sync mobile drawer nav
    const mobNav = document.getElementById('mob-nav-'+t);
    if (mobNav) {
      if (t === 'donate') mobNav.classList.toggle('active', t===tab);
      else mobNav.classList.toggle('active', t===tab);
    }
  });
  if (tab==='overview') {
    document.getElementById('page-title').textContent = T.page_overview;
    document.getElementById('page-sub').textContent   = T.page_overview_sub;
  } else if (tab==='accounts') {
    document.getElementById('page-title').textContent = T.page_accounts;
    document.getElementById('page-sub').textContent   = T.page_accounts_sub;
    if (statusData) renderAccountsList('accounts-list-full', statusData.accounts.list);
  } else if (tab==='donate') {
    document.getElementById('page-title').textContent = T.page_donate;
    document.getElementById('page-sub').textContent   = T.page_donate_sub;
    renderDonors();
  } else {
    document.getElementById('page-title').textContent = T.page_settings;
    document.getElementById('page-sub').textContent   = T.page_settings_sub;
    loadConfig();
  }
}

