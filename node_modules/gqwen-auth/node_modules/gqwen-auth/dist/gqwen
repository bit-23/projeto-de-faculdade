function formatExpiry(iso) {
  const diff = new Date(iso).getTime() - Date.now();
  if (diff < 0)
    return source_default.red("expired");
  if (diff < 60000)
    return source_default.yellow(`${Math.ceil(diff / 1000)}s`);
  if (diff < 3600000)
    return source_default.yellow(`${Math.ceil(diff / 60000)}m`);
  if (diff < 86400000)
    return `${Math.ceil(diff / 3600000)}h`;
  return `${Math.ceil(diff / 86400000)}d`;
}

