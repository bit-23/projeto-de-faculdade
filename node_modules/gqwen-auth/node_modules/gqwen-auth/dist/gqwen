// \u2500\u2500 Goals \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
function updateGoals(list) {
  const total = list.reduce((s, d) => s + d.amount, 0);

  // raised value
  const raisedEl = document.getElementById('donate-raised');
  if (raisedEl) raisedEl.textContent = fmtBRL(total);

  // which goal is active
  const activeGoal = GOALS.find(g => total < g) ?? GOALS[GOALS.length - 1];
  const goalEl = document.getElementById('donate-goal-current');
  if (goalEl) goalEl.textContent = fmtBRL(activeGoal);

  // global bar (capped at active goal)
  const globalPct = Math.min(100, (total / activeGoal) * 100);
  const barTotal  = document.getElementById('donate-bar-total');
  if (barTotal) barTotal.style.width = globalPct.toFixed(1) + '%';

  // per-goal bars
  GOALS.forEach((goal, idx) => {
    const n         = idx + 1;
    const pct       = Math.min(100, (total / goal) * 100);
    const reached   = total >= goal;
    const active    = goal === activeGoal;
    const fillColor = reached ? '#22c55e' : active ? '#ec4899' : '#374151';
    const badgeClr  = reached ? '#22c55e' : active ? '#ec4899' : '#6b7280';
    const badgeBg   = reached ? 'rgba(34,197,94,0.12)' : active ? 'rgba(236,72,153,0.12)' : '#222';

    const fill  = document.getElementById(\`donate-fill-\${n}\`);
    const pctEl = document.getElementById(\`donate-pct-\${n}\`);
    const badge = document.getElementById(\`donate-goal\${n}-badge\`);

    if (fill)  { fill.style.width = pct.toFixed(1) + '%'; fill.style.background = fillColor; }
    if (pctEl) { pctEl.textContent = pct.toFixed(0) + '%'; pctEl.style.color = badgeClr; }
    if (badge) { badge.style.color = badgeClr; badge.style.background = badgeBg; }
  });
}

// \u2500\u2500 Donors page render \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
function renderPage() {
  const el = document.getElementById('donors-list');
  if (!el) return;

  const list      = _allDonors;
  const total     = list.length;
  const pages     = Math.ceil(total / DONORS_PER_PAGE);
  const page      = Math.max(0, Math.min(_donorPage, pages - 1));
  _donorPage      = page;
  const start     = page * DONORS_PER_PAGE;
  const slice     = list.slice(start, start + DONORS_PER_PAGE);

  // count badge
  const countEl = document.getElementById('donors-count');
  if (countEl) countEl.textContent = \`\${total} apoiador\${total !== 1 ? 'es' : ''}\`;

  // rows
  el.innerHTML = slice.map((d, si) => {
    const i       = start + si;          // global index
    const medal   = MEDALS[i] ?? null;
    const isFirst = i === 0;
    const border  = isFirst ? '1px solid rgba(236,72,153,0.3)' : '1px solid #2a2a2a';
    const amtClr  = isFirst ? '#ec4899' : i < 3 ? '#e8e8e8' : '#9ca3af';
    const badge   = medal
      ? \`<div style="width:2rem;height:2rem;border-radius:50%;background:\${isFirst?'rgba(236,72,153,0.12)':'#1e1e1e'};display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;">\${medal}</div>\`
      : \`<div style="width:2rem;height:2rem;border-radius:50%;background:#1a1a1a;border:1px solid #2a2a2a;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:0.7rem;font-weight:700;color:#4b5563;">\${i+1}</div>\`;
    const nameStr = d.anonymous
      ? \`<span style="font-style:italic;color:#6b7280;">\${d.name}</span>\`
      : \`<span>\${d.name}</span>\`;
    return \`<div style="display:flex;align-items:center;gap:0.875rem;padding:0.75rem 1rem;border-radius:12px;background:#1a1a1a;border:\${border};">
      \${badge}
      <div style="flex:1;font-weight:600;font-size:0.875rem;color:#e8e8e8;">\${nameStr}</div>
      <span style="font-weight:700;font-size:0.875rem;color:\${amtClr};white-space:nowrap;">\${fmtBRL(d.amount)}</span>
    </div>\`;
  }).join('') || '<p style="font-size:0.85rem;color:#6b7280;padding:0.5rem 0;">Nenhum apoiador ainda.</p>';

  // pagination
  const pag  = document.getElementById('donors-pagination');
  const info = document.getElementById('donors-page-info');
  const prev = document.getElementById('donors-prev');
  const next = document.getElementById('donors-next');
  if (pag) {
    pag.style.display = pages > 1 ? 'flex' : 'none';
    if (info) info.textContent = \`P\xE1gina \${page + 1} de \${pages}\`;
    if (prev) prev.disabled = page === 0;
    if (next) next.disabled = page === pages - 1;
  }
}

function donorsChangePage(delta) {
  _donorPage += delta;
  renderPage();
  document.getElementById('donors-list')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// \u2500\u2500 Main entry point \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
function renderDonors() {
  // show fallback immediately
  _allDonors = DONORS;
  renderPage();
  updateGoals(DONORS);

  if (_donorsLoaded) return;
  fetch('/api/donors')
    .then(r => r.ok ? r.json() : null)
    .then(data => {
      if (data?.donors?.length) {
        _donorsLoaded = true;
        _allDonors    = data.donors;
        _donorPage    = 0;
        renderPage();
        updateGoals(data.donors);
      }
    })
    .catch(() => {});
}

// \u2500\u2500 Version update banner in dashboard \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
async function checkDashboardVersion() {
  try {
    const res = await fetch('/api/version');
    if (!res.ok) return;
    const { current, latest } = await res.json();
    if (!latest || latest === current) return;
    const banner = document.getElementById('dash-update-banner');
    const msg    = document.getElementById('dash-update-msg');
    if (banner && msg) {
      msg.textContent = \`Nova vers\xE3o dispon\xEDvel: v\${latest} (atual: v\${current}) \u2014 rode gqwen update\`;
      banner.classList.remove('hidden');
    }
  } catch {}
}

