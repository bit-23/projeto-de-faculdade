async function handleChatCompletions(req) {
  const start = Date.now();
  let body;
  try {
    body = await req.json();
  } catch {
    logReq("POST", "/v1/chat/completions", 400, Date.now() - start);
    return jsonResponse({ error: { message: "Invalid JSON body" } }, 400);
  }
  const model = typeof body.model === "string" ? body.model : null;
  const stream = body.stream === true;
  const excludeIds = new Set;
  let rotations = 0;
  for (let attempt = 0;attempt < MAX_RETRIES; attempt++) {
    const selected = selectAccount(model, excludeIds);
    if (!selected) {
      logReq("POST", "/v1/chat/completions", 503, Date.now() - start, { model });
      return jsonResponse({ error: { message: "No Qwen accounts available", type: "gqwen_error", code: 503 } }, 503);
    }
    if (isRateLimitedResult(selected)) {
      logReq("POST", "/v1/chat/completions", 429, Date.now() - start, { model, rotated: rotations });
      return jsonResponse({ error: { message: `All accounts rate limited. ${selected.retryAfterHuman}`, type: "gqwen_error", code: 429 } }, 429, { "Retry-After": selected.retryAfter });
    }
    const account = await checkAndRefreshAccount(selected);
    const label = account.email?.split("@")[0] ?? account.id.slice(0, 8);
    const upstreamUrl = buildQwenUrl(account.resource_url);
    const upstreamBody = injectSystemMsg(body);
    if (stream && Array.isArray(upstreamBody.messages)) {
      upstreamBody.stream_options = { include_usage: true };
    }
    let upstreamResp;
    try {
      upstreamResp = await fetch(upstreamUrl, {
        method: "POST",
        headers: buildQwenHeaders(account.access_token, stream),
        body: JSON.stringify(upstreamBody)
      });
    } catch (err) {
      excludeIds.add(account.id);
      rotations++;
      markAccountUnavailable(account.id, 503, err instanceof Error ? err.message : String(err), model);
      continue;
    }
    if (!upstreamResp.ok) {
      const errText = await upstreamResp.text();
      const { shouldFallback } = markAccountUnavailable(account.id, upstreamResp.status, errText, model);
      if (shouldFallback && attempt < MAX_RETRIES - 1) {
        console.log(`  ${source_default.yellow("\u21BB")} rotating away from ${source_default.cyan(label)} (${upstreamResp.status})`);
        excludeIds.add(account.id);
        rotations++;
        continue;
      }
      logReq("POST", "/v1/chat/completions", upstreamResp.status, Date.now() - start, { model, account: label, rotated: rotations });
      const ct = upstreamResp.headers.get("content-type") ?? "";
      if (ct.includes("json")) {
        try {
          return jsonResponse(JSON.parse(errText), upstreamResp.status);
        } catch {}
      }
      return new Response(errText, { status: upstreamResp.status, headers: { "Content-Type": ct || "text/plain", ...corsHeaders() } });
    }
    clearAccountError(account.id, model);
    if (stream) {
      const ms = Date.now() - start;
      let usage = { prompt: 0, completion: 0, total: 0 };
      const { readable, writable } = new TransformStream({
        transform(chunk, ctrl) {
          ctrl.enqueue(chunk);
          const u = extractTokens(new TextDecoder().decode(chunk));
          if (u.total > 0)
            usage = u;
        },
        flush() {
          logReq("POST", "/v1/chat/completions", 200, ms, { model, account: label, rotated: rotations, tokens: usage.total || undefined });
          if (usage.total > 0)
            recordUsage({ account_id: account.id, model: model ?? "", prompt_tokens: usage.prompt, completion_tokens: usage.completion, total_tokens: usage.total });
        }
      });
      upstreamResp.body.pipeTo(writable).catch(() => {});
      return new Response(readable, {
        headers: { "Content-Type": "text/event-stream", "Cache-Control": "no-cache", Connection: "keep-alive", "X-Accel-Buffering": "no", ...corsHeaders() }
      });
    }
    const data = await upstreamResp.json();
    const rawUsage = data["usage"];
    const promptTok = rawUsage?.prompt_tokens ?? 0;
    const completionTok = rawUsage?.completion_tokens ?? 0;
    const totalTok = rawUsage?.total_tokens ?? promptTok + completionTok;
    if (totalTok > 0)
      recordUsage({ account_id: account.id, model: model ?? "", prompt_tokens: promptTok, completion_tokens: completionTok, total_tokens: totalTok });
    logReq("POST", "/v1/chat/completions", 200, Date.now() - start, { model, account: label, rotated: rotations, tokens: totalTok || undefined });
    return jsonResponse(data);
  }
  logReq("POST", "/v1/chat/completions", 503, Date.now() - start, { model, rotated: rotations });
  return jsonResponse({ error: { message: "All retry attempts exhausted", type: "gqwen_error", code: 503 } }, 503);
}

