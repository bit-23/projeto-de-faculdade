// src/proxy/server.ts
function serveWizard() {
  return new Response(wizard_default, { headers: { "Content-Type": "text/html; charset=utf-8" } });
}
function serveDashboard() {
  return new Response(dashboard_default, { headers: { "Content-Type": "text/html; charset=utf-8" } });
}
var MAX_RETRIES = 3;
var modelsCache = null;
var MODELS_TTL = 10 * 60 * 1000;
async function fetchModels() {
  if (modelsCache && Date.now() - modelsCache.at < MODELS_TTL)
    return modelsCache.data;
  const accounts = listAccounts();
  const account = accounts.find((a) => a.is_active && a.test_status !== "unavailable");
  if (!account)
    return fallbackModels();
  try {
    const refreshed = await checkAndRefreshAccount(account);
    const resp = await fetch(buildQwenModelsUrl(refreshed.resource_url), {
      headers: buildQwenHeaders(refreshed.access_token, false),
      signal: AbortSignal.timeout(8000)
    });
    if (resp.ok) {
      const json2 = await resp.json();
      const raw = json2.data;
      if (raw && raw.length > 0) {
        const data = raw.map((m) => ({ id: m.id, object: "model", created: 1720000000, owned_by: "qwen" }));
        modelsCache = { data, at: Date.now() };
        return data;
      }
    }
  } catch {}
  return fallbackModels();
}
function fallbackModels() {
  const data = QWEN_MODELS_OAUTH.map((id) => ({ id, object: "model", created: 1720000000, owned_by: "qwen" }));
  modelsCache = { data, at: Date.now() };
  return data;
}
function logReq(method, path2, status, ms, meta) {
  const time = source_default.gray(new Date().toLocaleTimeString("pt-BR", { hour12: false }));
  const sc = status < 300 ? source_default.green : status < 400 ? source_default.cyan : status < 500 ? source_default.yellow : source_default.red;
  const lat = ms < 1000 ? source_default.gray(`${ms}ms`) : source_default.yellow(`${(ms / 1000).toFixed(1)}s`);
  let extras = "";
  if (meta?.model)
    extras += source_default.magenta(` ${meta.model}`);
  if (meta?.account)
    extras += source_default.gray(` \u2192 ${meta.account}`);
  if (meta?.rotated && meta.rotated > 0)
    extras += source_default.yellow(` \u21BB\xD7${meta.rotated}`);
  if (meta?.tokens)
    extras += source_default.gray(` [${meta.tokens}t]`);
  console.log(`  ${time} ${source_default.bold(method.padEnd(4))} ${path2}${extras} ${sc(String(status))} ${lat}`);
}
function corsHeaders() {
  return {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
    "Access-Control-Allow-Headers": "Content-Type, Authorization"
  };
}
function jsonResponse(data, status = 200, extra) {
  return Response.json(data, { status, headers: { ...corsHeaders(), ...extra } });
}
function injectSystemMsg(body) {
  const messages = Array.isArray(body.messages) ? body.messages : [];
  return { ...body, messages: [QWEN_SYSTEM_MSG, ...messages] };
}
function extractTokens(text) {
  const grab = (key) => {
    const m = text.match(new RegExp(`"${key}"\\s*:\\s*(\\d+)`));
    return m?.[1] ? parseInt(m[1], 10) : 0;
  };
  const prompt = grab("prompt_tokens");
  const completion = grab("completion_tokens");
  const total = grab("total_tokens") || prompt + completion;
  return { prompt, completion, total };
}
