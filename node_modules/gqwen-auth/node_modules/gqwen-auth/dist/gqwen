// src/commands/models.ts
async function modelsCommand() {
  const accounts = listAccounts();
  const account = accounts.find((a) => a.is_active && a.test_status !== "unavailable");
  if (!account) {
    console.error(source_default.red("\nNo active accounts. Run `gqwen add` first.\n"));
    process.exit(1);
  }
  const refreshed = await checkAndRefreshAccount(account);
  const url = buildQwenModelsUrl(refreshed.resource_url);
  const label = refreshed.email ?? refreshed.id.slice(0, 8);
  const spinner = ora(`Fetching models from ${url}...`).start();
  let models = [];
  let source = "static";
  try {
    const resp = await fetch(url, { headers: buildQwenHeaders(refreshed.access_token, false), signal: AbortSignal.timeout(8000) });
    if (resp.ok) {
      const json2 = await resp.json();
      if (json2.data?.length) {
        models = json2.data.map((m) => m.id);
        source = "api";
      }
    }
    if (source === "static")
      spinner.warn(source_default.yellow(`/models endpoint returned ${resp.status} \u2014 showing known models`));
  } catch {
    spinner.warn(source_default.yellow("Could not reach /models \u2014 showing known models"));
  }
  if (source === "api")
    spinner.succeed(`${models.length} models from API`);
  else
    models = QWEN_MODELS_OAUTH;
  console.log("");
  for (const id of models)
    console.log(`  ${source_default.cyan(id)}`);
  console.log("");
  console.log(source_default.gray(`  account:  ${label}`));
  console.log(source_default.gray(`  endpoint: ${url}`));
  if (source === "static")
    console.log(source_default.gray("  source:   static list (portal.qwen.ai OAuth does not expose /models)"));
  console.log("");
}

