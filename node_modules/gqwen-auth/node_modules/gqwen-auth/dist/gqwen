// \u2500\u2500 Wizard step transition \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
let isAnimating = false;
function goStep(n) {
  if (n === currentStep || isAnimating) return;
  isAnimating = true;

  const prev = document.getElementById('step-' + currentStep);
  const next = document.getElementById('step-' + n);
  const dir  = n > currentStep ? 1 : -1;
  const wrap = document.getElementById('wstep-wrap');

  gsap.killTweensOf([prev, next]);

  // 1. Snapshot prev height and lock wrapper so it doesn't collapse
  const prevH = prev.offsetHeight;
  wrap.style.height = prevH + 'px';

  // 2. Lay out next (invisible) beside prev using absolute so it doesn't push layout
  next.style.position = 'absolute';
  next.style.top = '0';
  next.style.left = '0';
  next.style.right = '0';
  next.classList.add('active'); // display:block via CSS
  gsap.set(next, { opacity: 0, x: dir * 48 });

  const nextH = next.offsetHeight;

  // 3. Animate wrapper to next height
  gsap.to(wrap, { height: nextH, duration: 0.3, ease: 'power2.inOut' });

  // 4. Slide prev out
  gsap.to(prev, {
    opacity: 0, x: -dir * 48, duration: 0.22, ease: 'power2.in',
    onComplete: () => {
      prev.classList.remove('active');
      gsap.set(prev, { clearProps: 'all' });
    }
  });

  // 5. Slide next in, then restore it to normal flow
  gsap.to(next, {
    opacity: 1, x: 0, duration: 0.28, delay: 0.08, ease: 'power2.out',
    onComplete: () => {
      // Remove absolute positioning \u2014 next is now the active in-flow step
      next.style.position = '';
      next.style.top = '';
      next.style.left = '';
      next.style.right = '';
      gsap.set(next, { clearProps: 'x,opacity' });
      wrap.style.height = '';
      isAnimating = false;
    }
  });

  // 6. Update dots
  for (let i = 0; i < 4; i++) {
    const d = document.getElementById('dot-' + i);
    d.classList.toggle('s-active', i === n);
    d.classList.toggle('s-done', i < n);
  }
  currentStep = n;
}

