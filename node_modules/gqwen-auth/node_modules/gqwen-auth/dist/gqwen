function serveOnCommand(options) {
  if (isRunning()) {
    console.log(`
  ${source_default.yellow("\u26A0")}  Proxy already running ${source_default.gray(`(PID ${readPid()})`)}
`);
    return;
  }
  const port = options.port ?? getProxyPort();
  const logFd = openSync(LOG_FILE, "a");
  const child = Bun.spawn(["bun", Bun.main, "_daemon", "--port", String(port)], {
    detached: true,
    stdio: ["ignore", logFd, logFd]
